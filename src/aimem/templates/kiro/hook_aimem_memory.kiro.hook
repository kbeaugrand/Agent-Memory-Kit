{
  "version": "v1",
  "hooks": [
    {
      "name": "aimem-inject-session",
      "description": "Inject AI memory into context when a session starts.",
      "trigger": "SessionStart",
      "action": {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/inject_memory.py --format text"
      },
      "timeout": 20,
      "enabled": true
    },
    {
      "name": "aimem-inject-prompt",
      "description": "Refresh AI memory context on each user prompt.",
      "trigger": "UserPromptSubmit",
      "action": {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/inject_memory.py --format text"
      },
      "timeout": 20,
      "enabled": true
    },
    {
      "name": "aimem-guard-memory",
      "description": "Block writing secrets into memory files before a tool runs.",
      "trigger": "PreToolUse",
      "action": {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/guard_memory.py --mode kiro"
      },
      "timeout": 15,
      "enabled": true
    },
    {
      "name": "aimem-consolidate-memory",
      "description": "Normalize and de-duplicate memory files after they are saved.",
      "trigger": "PostFileSave",
      "matcher": "\\.aimem/memory/.*\\.md$",
      "action": {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/consolidate_memory.py"
      },
      "timeout": 20,
      "enabled": true
    },
    {
      "name": "aimem-learn-session",
      "description": "Extract durable lessons and project coding rules after an agent turn.",
      "trigger": "Stop",
      "action": {
        "type": "agent",
        "prompt": "Invoke the lesson-learning skill for the completed conversation now. Extract high-confidence durable lessons, update memory, and create or update user-owned coding instructions or Kiro steering when a lesson is also a prescriptive coding rule. If nothing durable emerged, make no changes."
      },
      "timeout": 60,
      "enabled": true
    }
  ]
}
