{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/inject_memory.py --format copilot --event SessionStart",
        "windows": "{{PYTHON_COMMAND}} .aimem/hooks/inject_memory.py --format copilot --event SessionStart",
        "timeout": 20
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/guard_memory.py --mode copilot",
        "windows": "{{PYTHON_COMMAND}} .aimem/hooks/guard_memory.py --mode copilot",
        "timeout": 15
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/consolidate_memory.py --mode copilot",
        "windows": "{{PYTHON_COMMAND}} .aimem/hooks/consolidate_memory.py --mode copilot",
        "timeout": 20
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/learn_session.py",
        "windows": "{{PYTHON_COMMAND}} .aimem/hooks/learn_session.py",
        "timeout": 20
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/consolidate_memory.py",
        "windows": "{{PYTHON_COMMAND}} .aimem/hooks/consolidate_memory.py",
        "timeout": 20
      },
      {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/learn_session.py --cleanup",
        "windows": "{{PYTHON_COMMAND}} .aimem/hooks/learn_session.py --cleanup",
        "timeout": 10
      }
    ]
  }
}
