{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/inject_memory.py --format copilot --event SessionStart",
        "windows": "python .aimem/hooks/inject_memory.py --format copilot --event SessionStart",
        "timeout": 20
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/guard_memory.py --mode copilot",
        "windows": "python .aimem/hooks/guard_memory.py --mode copilot",
        "timeout": 15
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "{{PYTHON_COMMAND}} .aimem/hooks/consolidate_memory.py --mode copilot",
        "windows": "python .aimem/hooks/consolidate_memory.py --mode copilot",
        "timeout": 20
      }
    ]
  }
}
