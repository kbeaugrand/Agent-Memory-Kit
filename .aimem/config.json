{
  "aimem_version": "0.1.0",
  "index": {
    "dir": ".aimem/index",
    "vector_path": ".aimem/index/vector.json"
  },
  "mcp": {
    "default_context_chars": 12000,
    "default_search_limit": 20,
    "enabled": true,
    "proposal_dir": ".aimem/proposals",
    "server_name": "aimem"
  },
  "memory": {
    "deprecation_marker": "[DEPRECATED]",
    "max_entries_per_section": 200,
    "max_injection_chars": 12000,
    "redaction_patterns": [
      "(?i)\\b(api[_-]?key|secret|password|passwd|token|client[_-]?secret)\\b\\s*[:=]\\s*\\S+",
      "(?i)\\bbearer\\s+[A-Za-z0-9._\\-]{8,}",
      "(?i)\\bAKIA[0-9A-Z]{16}\\b",
      "(?i)\\bghp_[A-Za-z0-9]{20,}\\b",
      "(?i)\\bxox[baprs]-[A-Za-z0-9-]{10,}\\b",
      "-----BEGIN (?:RSA |EC |OPENSSH |DSA )?PRIVATE KEY-----"
    ],
    "warn_entries_per_section": 50
  },
  "python_command": "python3",
  "schema_version": 1,
  "scopes": {
    "agent": {
      "dir": ".aimem/memory/agents",
      "enabled": true,
      "inject": "none"
    },
    "project": {
      "enabled": true,
      "path": ".aimem/memory/project.md"
    },
    "session": {
      "enabled": true,
      "path": ".aimem/memory/session/current.md"
    },
    "user": {
      "enabled": false,
      "path": "~/.aimem/memory/user.md"
    }
  },
  "toolchains": {
    "copilot": true,
    "kiro": true
  }
}
